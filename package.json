{
  "name": "thermodash",
  "version": "1.0.0",
  "description": "Desktop application for thermocouple temperature monitoring and Excel reports.",
  "main": "electron/index.js",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter dashboard build",
    "dist": "pnpm build && electron-builder",
    "dist:win": "pnpm build && electron-builder --win nsis",
    "dist:linux": "pnpm build && electron-builder --linux deb",
    "dist:linux:appimage": "pnpm build && electron-builder --linux AppImage",
    "start": "turbo run start",
    "electron": "wait-on http://localhost:3000 && electron .",
    "dev:full": "concurrently \"pnpm dev\" \"wait-on http://localhost:3000 && pnpm electron\""
  },
  "keywords": [],
  "author": "Dmitrijs Sinickis",
  "license": "ISC",
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@serialport/parser-readline": "^13.0.0",
    "arduino-iot-js": "^0.9.7",
    "bindings": "^1.5.0",
    "chart.js": "^4.5.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "serialport": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "20.19.35",
    "@types/wait-on": "^5.3.4",
    "concurrently": "^9.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "turbo": "^2.8.10",
    "wait-on": "^9.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@serialport/bindings-cpp",
      "sharp",
      "unrs-resolver",
      "electron"
    ],
    "overrides": {
      "@types/node": "20.19.35"
    }
  },
  "build": {
    "appId": "com.thermodash.app",
    "productName": "ThermoDash",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "apps/dashboard/public/logo.png",
      "category": "Utility",
      "maintainer": "ThermoDash Maintainers <maintainers@thermodash.local>"
    },
    "files": [
      "electron/**/*",
      "assets/icon.ico",
      "apps/iot/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "apps/dashboard/.next/standalone",
        "to": "dashboard",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "apps/dashboard/.next/static",
        "to": "dashboard/apps/dashboard/.next/static"
      },
      {
        "from": "apps/dashboard/public",
        "to": "dashboard/apps/dashboard/public"
      }
    ]
  }
}
